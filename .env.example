# ============================================================
# BPJS Blast Message Automation — Environment Configuration
# Salin file ini ke .env dan sesuaikan nilainya
# ============================================================

# === CHANNEL AKTIF ===
SEND_WA=true
SEND_SMS=true

# ============================================================
# WHATSAPP SETTINGS
# ============================================================
# Jeda antar pengiriman pesan WA (detik) — mencegah banned
WA_DELAY_SECONDS=5

# Timeout menunggu halaman WA Web load (detik)
WA_TIMEOUT_SECONDS=30

# false = browser terlihat | true = background (headless)
# Disarankan false untuk pertama kali (perlu scan QR)
WA_HEADLESS=false

# Path folder penyimpanan sesi WA (QR scan hanya sekali)
WA_PROFILE_DIR=wa_profile

# ============================================================
# SMS / ADB SETTINGS
# ============================================================
# Jeda antar pengiriman SMS (detik)
SMS_DELAY_SECONDS=10

# ID device ADB (kosongkan jika hanya ada 1 HP terhubung)
# Cek dengan: adb devices
ADB_DEVICE_ID=

# Waktu tunggu setelah buka SMS composer sebelum tap Send (detik)
ADB_SEND_WAIT=3

# ============================================================
# RETRY SETTINGS
# ============================================================
RETRY_FAILED=true
MAX_RETRY=2

# ============================================================
# NOTIFIKASI ADMIN
# ============================================================
# Kirim WA ke admin setelah semua pesan terkirim
NOTIFY_ADMIN=false
ADMIN_PHONE=628xxxxxxxxxx

# ============================================================
# SCHEDULER (nonaktif by default)
# ============================================================
SCHEDULER_ENABLED=false
# Format cron: menit jam hari bulan hari_minggu
# Contoh: 0 9 * * * = setiap hari jam 09:00
SCHEDULER_CRON=0 9 * * *

# ============================================================
# PATH & FILE
# ============================================================
INPUT_CSV=data/input.csv
TEMPLATE_FILE=templates/bpjs_message.txt
REPORT_DIR=data/reports
SCREENSHOT_DIR=screenshots
STATE_FILE=.state.json
